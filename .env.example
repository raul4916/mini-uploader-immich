# Copy to .env and edit if you want.
# All of these are OPTIONAL — the app runs fine without this file.

# Externally-reachable URL for this app. The QR code embeds this, so it must be
# reachable from the phone scanning it. Leave the default for local testing.
PUBLIC_BASE_URL=http://localhost:8000

# Host port the app is published on (inside the container it's always 8000).
APP_PORT=8000

# Max upload size in megabytes.
MAX_UPLOAD_MB=50

# Optional VirusTotal API key. Only used as a fallback if the built-in ClamAV
# container is down. Leave blank unless you have one.
VT_API_KEY=
