# All values here are OPTIONAL — the app generates its own secret on first run
# and the admin account is created through the web UI.

# If you want to pin a specific encryption key instead of letting the app
# generate one, paste a Fernet key here. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=

CLAMD_HOST=localhost
CLAMD_PORT=3310
VT_API_KEY=
DB_PATH=./data/app.db
MAX_UPLOAD_MB=50
PUBLIC_BASE_URL=http://localhost:8000
